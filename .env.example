# OpenAI-compatible API (UvA proxy or your own endpoint)
LLM_API_BASE=https://llmproxy.uva.nl
LLM_API_KEY=your-api-key-here

# Model selection
# Available: gpt-4o, gpt-4.1-nano, gpt-4.1, gpt-4o-mini, gpt-5, o3-mini, gpt-5.1
LLM_MODEL=gpt-4.1-nano
LLM_EMBEDDING=text-embedding-3-large

# ChromaDB
CHROMA_COLLECTION=cahiers-chunk-08
CHROMA_PERSIST_DIR=.
